---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MortgageCalculator from '../../components/MortgageCalculator.tsx';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Home Affordability Calculator",
  "description": "Free affordability calculator to estimate how much house you can afford based on your income, debts, and down payment.",
  "provider": { "@type": "MortgageBroker", "name": "Intra Mortgage" },
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "Web"
};

const factors = [
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    title: "Gross Monthly Income",
    desc: "Your total pre-tax income from all sources. Lenders use this as the starting point for determining how much you can borrow.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" /></svg>`,
    title: "Existing Monthly Debts",
    desc: "Car payments, student loans, credit card minimums, and other recurring debts all count toward your debt-to-income ratio.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z" /></svg>`,
    title: "Credit Score",
    desc: "A higher credit score qualifies you for lower interest rates, which directly increases the home price you can afford.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" /></svg>`,
    title: "Down Payment Size",
    desc: "A larger down payment reduces your loan amount and monthly payment. Putting 20% down also eliminates the need for PMI.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>`,
    title: "Interest Rate",
    desc: "Even small rate differences dramatically affect affordability. A 0.5% rate drop on a $400K loan saves over $100/month.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>`,
    title: "Property Taxes & Insurance",
    desc: "These costs vary significantly by location and are added to your monthly payment, reducing the loan amount you qualify for.",
  },
];
---

<BaseLayout
  title="Home Affordability Calculator | Intra Mortgage"
  description="Use our free affordability calculator to determine how much house you can afford. Learn about the 28/36 rule, debt-to-income ratios, and factors that affect your buying power."
  canonicalUrl="/tools/affordability-calculator"
  schema={schema}
>

  <!-- ==================== HERO ==================== -->
  <section class="relative overflow-hidden -mt-18">
    <img
      src="https://images.unsplash.com/photo-1560518883-ce09059eeffa?w=1600&h=600&fit=crop&crop=center"
      alt="Couple reviewing home buying documents at a table"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-navy-950/95 via-navy-950/85 to-navy-950/50"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-36 pb-20 md:pt-44 md:pb-24">
      <div class="max-w-2xl">
        <p class="text-cyan-500 text-xs font-semibold tracking-[3px] uppercase mb-4">Free Tools</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-[1.08] mb-6">
          Affordability<br /><span class="text-gradient">Calculator</span>
        </h1>
        <p class="text-white/65 text-base md:text-lg leading-relaxed max-w-xl">
          Find out how much home you can comfortably afford. Use our calculator to estimate your budget based on price, down payment, and interest rate.
        </p>
      </div>
    </div>
  </section>

  <!-- ==================== BREADCRUMB ==================== -->
  <div class="bg-navy-900 border-b border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <nav class="flex items-center gap-2 text-xs text-white/40" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/tools/mortgage-calculator" class="hover:text-white transition-colors">Tools</a>
        <span>/</span>
        <span class="text-white/70">Affordability Calculator</span>
      </nav>
    </div>
  </div>

  <!-- ==================== CALCULATOR + CONTENT ==================== -->
  <section class="section-padding bg-navy-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-[1fr_320px] gap-12">

        <!-- Main Content -->
        <div>
          <div class="grid md:grid-cols-2 gap-8 items-start mb-16">
            <div class="fade-up">
              <h2 class="text-white font-bold text-lg mb-3">Estimate Your Budget</h2>
              <p class="text-white/50 text-sm leading-relaxed mb-6">Adjust the sliders to find a comfortable price range. Start with the maximum home price you're considering and see what the monthly payment looks like.</p>
              <MortgageCalculator client:load />
            </div>

            <div class="space-y-6 fade-up">
              <!-- 28/36 Rule Card -->
              <div class="glass rounded-2xl p-6">
                <h3 class="text-white font-bold text-lg mb-3">The 28/36 Rule</h3>
                <p class="text-white/50 text-sm leading-relaxed mb-4">
                  Most lenders follow the 28/36 rule to determine how much you can borrow. This guideline helps ensure your housing costs stay manageable.
                </p>
                <div class="grid grid-cols-2 gap-4">
                  <div class="bg-cyan-500/8 rounded-xl p-4 border border-cyan-500/15 text-center">
                    <div class="text-cyan-500 text-3xl font-extrabold">28%</div>
                    <div class="text-white/40 text-xs mt-1 leading-snug">Max housing costs as % of gross income</div>
                  </div>
                  <div class="bg-white/[0.03] rounded-xl p-4 border border-white/6 text-center">
                    <div class="text-white text-3xl font-extrabold">36%</div>
                    <div class="text-white/40 text-xs mt-1 leading-snug">Max total debt as % of gross income</div>
                  </div>
                </div>
              </div>

              <!-- Quick Example -->
              <div class="glass rounded-2xl p-6">
                <h3 class="text-white font-bold text-lg mb-3">Quick Example</h3>
                <p class="text-white/50 text-sm leading-relaxed mb-4">
                  Here's how the 28/36 rule works for a household earning $8,000 per month (gross):
                </p>
                <div class="space-y-3">
                  <div class="flex justify-between items-center py-2 border-b border-white/6">
                    <span class="text-white/50 text-sm">Gross monthly income</span>
                    <span class="text-white font-bold text-sm">$8,000</span>
                  </div>
                  <div class="flex justify-between items-center py-2 border-b border-white/6">
                    <span class="text-white/50 text-sm">Max housing payment (28%)</span>
                    <span class="text-cyan-500 font-bold text-sm">$2,240</span>
                  </div>
                  <div class="flex justify-between items-center py-2 border-b border-white/6">
                    <span class="text-white/50 text-sm">Max total debt payments (36%)</span>
                    <span class="text-white font-bold text-sm">$2,880</span>
                  </div>
                  <div class="flex justify-between items-center py-2">
                    <span class="text-white/50 text-sm">Approx. affordable home price</span>
                    <span class="text-amber-400 font-bold text-sm">~$375,000</span>
                  </div>
                </div>
                <p class="text-white/30 text-xs mt-3">Assumes 20% down, 6.25% rate, 30-year term. Actual amounts depend on individual factors.</p>
              </div>
            </div>
          </div>

          <!-- Factors That Affect Affordability -->
          <div class="mb-16 fade-up">
            <p class="text-cyan-500 text-xs font-semibold tracking-[3px] uppercase mb-3">Key Factors</p>
            <h2 class="text-3xl md:text-4xl font-extrabold text-white leading-tight mb-4">
              What Affects How Much You Can Afford?
            </h2>
            <p class="text-white/50 text-sm leading-relaxed max-w-2xl mb-8">
              Your home buying budget depends on more than just your income. Here are the factors lenders evaluate when determining your maximum loan amount.
            </p>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
              {factors.map((factor) => (
                <div class="glass rounded-2xl p-6 hover-card">
                  <div class="w-12 h-12 bg-cyan-500/10 border border-cyan-500/20 rounded-xl flex items-center justify-center text-cyan-500 mb-4">
                    <Fragment set:html={factor.icon} />
                  </div>
                  <h3 class="text-white text-sm font-bold mb-2">{factor.title}</h3>
                  <p class="text-white/45 text-xs leading-relaxed">{factor.desc}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- Tips Section -->
          <div class="fade-up">
            <div class="glass rounded-2xl p-8">
              <h2 class="text-white font-bold text-xl mb-4">Tips for Maximizing Your Buying Power</h2>
              <div class="space-y-4 text-white/55 text-sm leading-relaxed">
                <p>
                  <strong class="text-white/70">Reduce existing debt first.</strong> Paying down credit cards, car loans, or student loans before applying for a mortgage directly improves your debt-to-income ratio. This can increase your approved loan amount significantly.
                </p>
                <p>
                  <strong class="text-white/70">Save a larger down payment.</strong> Beyond lowering your monthly payment, a larger down payment shows lenders you're financially stable. Putting 20% or more down also eliminates private mortgage insurance (PMI), saving you $100-$300+ per month.
                </p>
                <p>
                  <strong class="text-white/70">Improve your credit score.</strong> Even a 20-point improvement in your credit score can unlock better interest rates. Pay bills on time, reduce credit utilization below 30%, and avoid opening new accounts before applying.
                </p>
                <p>
                  <strong class="text-white/70">Consider total housing costs.</strong> Your mortgage payment is only part of the picture. Budget for property taxes, homeowner's insurance, HOA fees, maintenance, and utilities. A good rule of thumb is to budget an additional 1-2% of the home's value annually for maintenance.
                </p>
                <p>
                  <strong class="text-white/70">Don't max out your budget.</strong> Just because you qualify for a certain amount doesn't mean you should spend it all. Leave room for savings, emergencies, and the lifestyle you want. Financial comfort is more important than square footage.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="fade-up">
          <div class="lg:sticky lg:top-28 space-y-6">
            <div class="glass rounded-2xl p-6">
              <h3 class="text-white text-sm font-bold mb-4">Related Tools</h3>
              <div class="space-y-2">
                <a href="/tools/mortgage-calculator" class="block px-3 py-2.5 rounded-lg text-sm text-white/50 hover:text-white hover:bg-white/5 transition-all">
                  Mortgage Calculator
                </a>
                <a href="/tools/refinance-calculator" class="block px-3 py-2.5 rounded-lg text-sm text-white/50 hover:text-white hover:bg-white/5 transition-all">
                  Refinance Calculator
                </a>
              </div>
            </div>

            <div class="glass rounded-2xl p-6">
              <h3 class="text-white text-sm font-bold mb-3">Related Articles</h3>
              <div class="space-y-2">
                <a href="/resources/how-much-house-can-you-afford" class="block px-3 py-2.5 rounded-lg text-sm text-white/50 hover:text-white hover:bg-white/5 transition-all">
                  How Much House Can You Afford?
                </a>
                <a href="/resources/first-time-homebuyer-guide" class="block px-3 py-2.5 rounded-lg text-sm text-white/50 hover:text-white hover:bg-white/5 transition-all">
                  First-Time Homebuyer Guide
                </a>
                <a href="/resources/mortgage-rate-forecast" class="block px-3 py-2.5 rounded-lg text-sm text-white/50 hover:text-white hover:bg-white/5 transition-all">
                  Mortgage Rate Forecast
                </a>
              </div>
            </div>

            <div class="bg-gradient-to-br from-cyan-500/15 to-cyan-600/10 rounded-2xl p-6 border border-cyan-500/20">
              <h3 class="text-white text-sm font-bold mb-2">Find Out What You Qualify For</h3>
              <p class="text-white/50 text-xs leading-relaxed mb-4">
                Get a personalized pre-approval based on your actual financial picture. It only takes a few minutes.
              </p>
              <a href="/apply" class="block bg-cyan-500 hover:bg-cyan-400 text-white text-center py-3 rounded-xl font-bold text-sm transition-colors">
                Get Pre-Approved &rarr;
              </a>
            </div>
          </div>
        </aside>

      </div>
    </div>
  </section>

  <!-- ==================== CTA ==================== -->
  <section class="relative overflow-hidden">
    <img
      src="https://images.unsplash.com/photo-1600585154526-990dced4db0d?w=1600&h=500&fit=crop"
      alt="Beautiful home with warm interior lighting"
      class="absolute inset-0 w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-cyan-500/92 to-cyan-600/88"></div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-3">Ready to Start House Hunting?</h2>
      <p class="text-white/85 text-base mb-8">Get pre-approved and shop with confidence. Our team will help you find the perfect loan for your budget.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/apply" class="inline-block bg-white text-cyan-600 text-sm font-bold px-10 py-4 rounded-xl hover:bg-white/90 transition-colors">
          Get Pre-Approved &rarr;
        </a>
        <a href="/company/contact" class="inline-block bg-white/20 text-white text-sm font-bold px-10 py-4 rounded-xl border border-white/30 hover:bg-white/30 transition-colors">
          Talk to an Expert
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
