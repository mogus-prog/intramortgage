---
import { url } from '../../utils/links';
import BaseLayout from '../../layouts/BaseLayout.astro';
import MortgageCalculator from '../../components/MortgageCalculator.tsx';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Refinance Savings Calculator",
  "description": "Free refinance calculator to estimate your monthly savings. Compare your current mortgage payment with a new refinanced payment.",
  "provider": { "@type": "MortgageBroker", "name": "Intra Mortgage" },
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "Web"
};

const reasons = [
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    title: "Lower Your Monthly Payment",
    desc: "Refinancing to a lower interest rate can reduce your monthly payment by hundreds of dollars, freeing up cash for other priorities.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>`,
    title: "Shorten Your Loan Term",
    desc: "Switch from a 30-year to a 15-year mortgage and pay off your home faster while saving significantly on total interest paid.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`,
    title: "Eliminate PMI",
    desc: "If your home has gained equity, refinancing can help you drop private mortgage insurance and save $100-$300+ per month.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" /></svg>`,
    title: "Cash-Out for Big Goals",
    desc: "Tap into your home equity to consolidate debt, fund home improvements, or cover major expenses at a lower rate than personal loans.",
  },
];

const steps = [
  { num: "01", title: "Check Your Rate", desc: "Start with a free rate quote. We'll review your credit, equity, and financial picture to find the best option." },
  { num: "02", title: "Compare & Choose", desc: "We'll present multiple refinance options side by side so you can pick the one that fits your goals." },
  { num: "03", title: "Lock & Process", desc: "Lock in your rate and we'll handle the paperwork, appraisal coordination, and title work." },
  { num: "04", title: "Close & Save", desc: "Sign your documents and start enjoying your new, lower payment. Most refinances close in 21 days or less." },
];
---

<BaseLayout
  title="Refinance Savings Calculator | Intra Mortgage"
  description="Use our free refinance calculator to estimate your monthly savings. Compare your current mortgage with a new rate and see how much you could save by refinancing."
  canonicalUrl="/tools/refinance-calculator"
  schema={schema}
>

  <!-- ==================== HERO ==================== -->
  <section class="relative overflow-hidden -mt-18">
    <img
      src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=1600&h=600&fit=crop&crop=center"
      alt="Beautiful modern home exterior with manicured landscaping"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-navy-950/95 via-navy-950/85 to-navy-950/50"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-36 pb-20 md:pt-44 md:pb-24">
      <div class="max-w-2xl">
        <p class="text-cyan-500 text-xs font-semibold tracking-[3px] uppercase mb-4">Free Tools</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-[1.08] mb-6">
          Refinance Savings<br /><span class="text-gradient">Calculator</span>
        </h1>
        <p class="text-white/65 text-base md:text-lg leading-relaxed max-w-xl">
          See how much you could save by refinancing your mortgage. Adjust the sliders to compare your current payment with a potential new rate.
        </p>
      </div>
    </div>
  </section>

  <!-- ==================== BREADCRUMB ==================== -->
  <div class="bg-navy-900 border-b border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <nav class="flex items-center gap-2 text-xs text-white/40" aria-label="Breadcrumb">
        <a href={url("/")} class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href={url("/tools/mortgage-calculator")} class="hover:text-white transition-colors">Tools</a>
        <span>/</span>
        <span class="text-white/70">Refinance Calculator</span>
      </nav>
    </div>
  </div>

  <!-- ==================== CALCULATOR ==================== -->
  <section class="section-padding bg-navy-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-[1fr_320px] gap-12">

        <!-- Main Content -->
        <div>
          <div class="grid md:grid-cols-2 gap-8 items-start mb-16">
            <div class="fade-up">
              <h2 class="text-white font-bold text-lg mb-3">Estimate Your New Payment</h2>
              <p class="text-white/50 text-sm leading-relaxed mb-6">Use the calculator below to model a new loan. Set the home price to your current home value and adjust the rate to today's rates to see your potential savings.</p>
              <MortgageCalculator client:load baseUrl={import.meta.env.BASE_URL} />
            </div>

            <div class="fade-up">
              <div class="glass rounded-2xl p-6">
                <h3 class="text-white font-bold text-lg mb-4">Current vs. New Payment</h3>
                <p class="text-white/50 text-sm leading-relaxed mb-5">Compare your existing mortgage details with the new estimate from the calculator to see the difference.</p>

                <div class="space-y-4">
                  <div class="bg-white/[0.03] rounded-xl p-4 border border-white/6">
                    <div class="text-white/40 text-xs font-medium mb-1">Example: Current Payment</div>
                    <div class="text-white text-2xl font-extrabold">$2,089</div>
                    <div class="text-white/30 text-xs">6.75% rate &middot; 30-year fixed &middot; $350K loan</div>
                  </div>
                  <div class="flex items-center justify-center">
                    <div class="w-8 h-8 rounded-full bg-cyan-500/15 border border-cyan-500/25 flex items-center justify-center">
                      <svg class="w-4 h-4 text-cyan-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
                    </div>
                  </div>
                  <div class="bg-cyan-500/8 rounded-xl p-4 border border-cyan-500/15">
                    <div class="text-cyan-400 text-xs font-medium mb-1">Example: New Payment</div>
                    <div class="text-cyan-500 text-2xl font-extrabold">$1,896</div>
                    <div class="text-white/30 text-xs">5.875% rate &middot; 30-year fixed &middot; $340K loan</div>
                  </div>
                </div>

                <div class="mt-5 bg-white/[0.03] rounded-xl p-4 border border-white/6 text-center">
                  <div class="text-white/40 text-xs mb-1">Potential Monthly Savings</div>
                  <div class="text-amber-400 text-3xl font-extrabold">$193</div>
                  <div class="text-white/25 text-xs mt-1">That's $2,316 saved per year</div>
                </div>
              </div>
            </div>
          </div>

          <!-- When to Refinance -->
          <div class="mb-16 fade-up">
            <p class="text-cyan-500 text-xs font-semibold tracking-[3px] uppercase mb-3">Why Refinance?</p>
            <h2 class="text-3xl md:text-4xl font-extrabold text-white leading-tight mb-4">
              Top Reasons Homeowners Refinance
            </h2>
            <p class="text-white/50 text-sm leading-relaxed max-w-2xl mb-8">
              Refinancing replaces your existing mortgage with a new one — ideally with better terms. Here are the most common reasons homeowners choose to refinance.
            </p>
            <div class="grid sm:grid-cols-2 gap-5">
              {reasons.map((reason) => (
                <div class="glass rounded-2xl p-6 hover-card">
                  <div class="w-12 h-12 bg-cyan-500/10 border border-cyan-500/20 rounded-xl flex items-center justify-center text-cyan-500 mb-4">
                    <Fragment set:html={reason.icon} />
                  </div>
                  <h3 class="text-white text-base font-bold mb-2">{reason.title}</h3>
                  <p class="text-white/45 text-sm leading-relaxed">{reason.desc}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- How Refinancing Works -->
          <div class="mb-16 fade-up">
            <p class="text-cyan-500 text-xs font-semibold tracking-[3px] uppercase mb-3">The Process</p>
            <h2 class="text-3xl md:text-4xl font-extrabold text-white leading-tight mb-4">
              How Refinancing Works
            </h2>
            <p class="text-white/50 text-sm leading-relaxed max-w-2xl mb-8">
              Refinancing is simpler than you might think. Here's a quick look at the four steps from rate quote to closing day.
            </p>
            <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
              {steps.map((step) => (
                <div class="glass rounded-2xl p-6 hover-card">
                  <div class="text-cyan-500 text-2xl font-extrabold mb-3">{step.num}</div>
                  <h3 class="text-white text-sm font-bold mb-2">{step.title}</h3>
                  <p class="text-white/45 text-xs leading-relaxed">{step.desc}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- When Should You Refinance -->
          <div class="fade-up">
            <div class="glass rounded-2xl p-8">
              <h2 class="text-white font-bold text-xl mb-4">When Does It Make Sense to Refinance?</h2>
              <div class="space-y-4 text-white/55 text-sm leading-relaxed">
                <p>
                  The general rule of thumb is that refinancing makes sense when you can lower your interest rate by at least 0.5% to 1%. However, the real answer depends on your specific situation — how long you plan to stay in the home, your closing costs, and your financial goals.
                </p>
                <p>
                  <strong class="text-white/70">The break-even point</strong> is the number of months it takes for your monthly savings to cover the closing costs of the refinance. If you plan to stay in your home longer than the break-even period, refinancing likely makes financial sense.
                </p>
                <p>
                  <strong class="text-white/70">Consider the total cost of the loan.</strong> While a lower monthly payment is attractive, extending your loan term means paying more interest over the life of the loan. A 15-year refinance can save you tens of thousands in total interest compared to resetting to a new 30-year term.
                </p>
                <p>
                  <strong class="text-white/70">Your credit score matters.</strong> Since you took out your original mortgage, your credit score may have improved, qualifying you for significantly better rates. Even a small rate reduction on a large balance can translate to major savings.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="fade-up">
          <div class="lg:sticky lg:top-28 space-y-6">
            <div class="glass rounded-2xl p-6">
              <h3 class="text-white text-sm font-bold mb-4">Related Tools</h3>
              <div class="space-y-2">
                <a href={url("/tools/mortgage-calculator")} class="block px-3 py-2.5 rounded-lg text-sm text-white/50 hover:text-white hover:bg-white/5 transition-all">
                  Mortgage Calculator
                </a>
                <a href={url("/tools/affordability-calculator")} class="block px-3 py-2.5 rounded-lg text-sm text-white/50 hover:text-white hover:bg-white/5 transition-all">
                  Affordability Calculator
                </a>
              </div>
            </div>

            <div class="glass rounded-2xl p-6">
              <h3 class="text-white text-sm font-bold mb-3">Related Articles</h3>
              <div class="space-y-2">
                <a href={url("/resources/how-much-house-can-you-afford")} class="block px-3 py-2.5 rounded-lg text-sm text-white/50 hover:text-white hover:bg-white/5 transition-all">
                  How Much House Can You Afford?
                </a>
                <a href={url("/resources/mortgage-rate-forecast")} class="block px-3 py-2.5 rounded-lg text-sm text-white/50 hover:text-white hover:bg-white/5 transition-all">
                  Mortgage Rate Forecast
                </a>
              </div>
            </div>

            <div class="bg-gradient-to-br from-cyan-500/15 to-cyan-600/10 rounded-2xl p-6 border border-cyan-500/20">
              <h3 class="text-white text-sm font-bold mb-2">Ready to Refinance?</h3>
              <p class="text-white/50 text-xs leading-relaxed mb-4">
                Get a personalized rate quote in minutes. No obligation, no impact to your credit score.
              </p>
              <a href={url("/apply")} class="block bg-cyan-500 hover:bg-cyan-400 text-white text-center py-3 rounded-xl font-bold text-sm transition-colors">
                Get Your Rate &rarr;
              </a>
            </div>
          </div>
        </aside>

      </div>
    </div>
  </section>

  <!-- ==================== CTA ==================== -->
  <section class="relative overflow-hidden">
    <img
      src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=1600&h=500&fit=crop"
      alt="Elegant home with a lush green yard"
      class="absolute inset-0 w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-cyan-500/92 to-cyan-600/88"></div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-3">Start Saving with a Refinance</h2>
      <p class="text-white/85 text-base mb-8">Our team will walk you through every option and help you find the right refinance for your goals.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={url("/apply")} class="inline-block bg-white text-cyan-600 text-sm font-bold px-10 py-4 rounded-xl hover:bg-white/90 transition-colors">
          Get Pre-Approved &rarr;
        </a>
        <a href={url("/company/contact")} class="inline-block bg-white/20 text-white text-sm font-bold px-10 py-4 rounded-xl border border-white/30 hover:bg-white/30 transition-colors">
          Talk to an Expert
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
