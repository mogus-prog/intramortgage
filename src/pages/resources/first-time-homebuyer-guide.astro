---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { url } from '../../utils/links';

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What credit score do I need to buy a house?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The minimum credit score depends on the loan type. Conventional loans typically require 620+, FHA loans require 580+ (or 500 with 10% down), and VA loans have no official minimum but most lenders prefer 620+. A score of 740+ will qualify you for the best interest rates."
      }
    },
    {
      "@type": "Question",
      "name": "How much do I need for a down payment on my first home?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "First-time buyers have several low down payment options. Conventional loans allow as little as 3% down, FHA loans require 3.5%, and VA and USDA loans offer 0% down. Many state and local programs also provide down payment assistance grants."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between pre-qualification and pre-approval?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Pre-qualification is a quick estimate based on self-reported financial information. Pre-approval is a more thorough process where a lender verifies your income, assets, and credit to issue a conditional commitment for a specific loan amount. Pre-approval carries much more weight with sellers."
      }
    },
    {
      "@type": "Question",
      "name": "How long does it take to buy a house from start to finish?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The typical home buying timeline is 3 to 6 months from start to finish. This includes 1-2 months of preparation (credit check, pre-approval, saving), 1-3 months of house hunting, and 30-45 days from accepted offer to closing."
      }
    },
    {
      "@type": "Question",
      "name": "What are closing costs and how much should I expect to pay?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Closing costs are fees paid at the time of your home purchase, typically ranging from 2-5% of the loan amount. They include appraisal fees, title insurance, attorney fees, origination charges, and prepaid items like property taxes and insurance. On a $350,000 loan, expect $7,000-$17,500."
      }
    },
    {
      "@type": "Question",
      "name": "Should I use a real estate agent as a first-time buyer?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. A buyer's agent provides expert guidance through the process, helps you find homes, negotiates on your behalf, and coordinates with your lender and the title company. In most cases, the seller pays the buyer's agent commission, so the service costs you nothing."
      }
    }
  ]
};

const publishDate = "2026-03-10";
const updateDate = "2026-03-18";

const timeline = [
  { phase: "6+ Months Before", title: "Build Your Foundation", items: ["Check your credit report and score", "Start tracking your spending and saving", "Pay down high-interest debts", "Research neighborhoods and price ranges"] },
  { phase: "3-6 Months Before", title: "Get Financially Ready", items: ["Save for your down payment and closing costs", "Gather financial documents (tax returns, pay stubs, bank statements)", "Get pre-approved for a mortgage", "Choose a trusted real estate agent"] },
  { phase: "1-3 Months Before", title: "Find Your Home", items: ["Tour homes and attend open houses", "Make an offer when you find the right one", "Negotiate price and terms", "Complete the home inspection"] },
  { phase: "30-45 Days to Close", title: "Finalize Everything", items: ["Lock in your interest rate", "Complete the appraisal process", "Review and sign closing documents", "Get the keys to your new home"] },
];
---

<BaseLayout
  title="First-Time Homebuyer Guide 2026 | Intra Mortgage"
  description="The complete guide to buying your first home. Learn about credit scores, saving for a down payment, choosing the right loan, and the home buying process step by step."
  canonicalUrl="/resources/first-time-homebuyer-guide"
  schema={schema}
>

  <!-- ==================== HERO ==================== -->
  <section class="relative overflow-hidden -mt-18">
    <img
      src="https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=1600&h=600&fit=crop&crop=center"
      alt="Couple reviewing documents together at a bright kitchen table"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-navy-950/95 via-navy-950/85 to-navy-950/50"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-36 pb-20 md:pt-44 md:pb-24">
      <div class="max-w-2xl">
        <p class="text-cyan-500 text-xs font-semibold tracking-[3px] uppercase mb-4">First-Time Buyers</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-[1.08] mb-6">
          The Complete Guide to<br />Buying Your <span class="text-gradient">First Home</span>
        </h1>
        <div class="flex items-center gap-4 text-white/40 text-xs">
          <time datetime={publishDate}>March 10, 2026</time>
          <span>&middot;</span>
          <span>8 min read</span>
          <span>&middot;</span>
          <span>Updated <time datetime={updateDate}>March 18, 2026</time></span>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== BREADCRUMB ==================== -->
  <div class="bg-navy-900 border-b border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <nav class="flex items-center gap-2 text-xs text-white/40" aria-label="Breadcrumb">
        <a href={url("/")} class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href={url("/resources")} class="hover:text-white transition-colors">Resources</a>
        <span>/</span>
        <span class="text-white/70">First-Time Homebuyer Guide</span>
      </nav>
    </div>
  </div>

  <!-- ==================== ARTICLE ==================== -->
  <section class="section-padding bg-navy-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-[1fr_320px] gap-12">

        <!-- Article Content -->
        <article class="max-w-none">

          <!-- Introduction -->
          <div class="fade-up mb-12">
            <div class="text-white/60 text-base leading-relaxed space-y-4">
              <p class="text-lg text-white/70">
                Buying your first home is exciting, nerve-wracking, and one of the most rewarding things you'll ever do. It's also a process with a lot of moving parts. This guide breaks it all down so you know exactly what to expect at every stage.
              </p>
              <p>
                Whether you're just starting to think about homeownership or you're ready to make an offer next month, this guide will help you navigate the journey from first thought to front door.
              </p>
            </div>
          </div>

          <!-- Section: Getting Started -->
          <div class="fade-up mb-12">
            <h2 class="text-2xl md:text-3xl font-extrabold text-white mb-4">Getting Started: Are You Ready?</h2>
            <div class="text-white/55 text-sm leading-relaxed space-y-4">
              <p>
                Before diving into the home search, take an honest look at your financial readiness. Buying a home involves more than qualifying for a loan — it means being prepared for the ongoing financial responsibilities of homeownership.
              </p>
              <p>
                Ask yourself a few key questions: Do you have a stable income? Have you been at your job for at least two years? Do you have savings beyond what you'll use for a down payment? Are your monthly debts manageable? If you can answer yes to these, you're likely in a strong position to start.
              </p>
            </div>
            <div class="glass rounded-2xl p-6 mt-6">
              <h3 class="text-white font-bold text-base mb-4">First-Time Buyer Readiness Checklist</h3>
              <div class="grid sm:grid-cols-2 gap-3">
                {[
                  "Stable employment (2+ years)",
                  "Emergency fund (3-6 months expenses)",
                  "Down payment savings",
                  "Manageable monthly debt load",
                  "Credit score above 620",
                  "No major purchases planned",
                  "Understanding of total housing costs",
                  "Pre-approval from a lender",
                ].map((item) => (
                  <div class="flex items-start gap-2">
                    <div class="w-5 h-5 shrink-0 rounded bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center mt-0.5">
                      <svg class="w-3 h-3 text-cyan-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                    </div>
                    <span class="text-white/50 text-sm">{item}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- Section: Credit Scores -->
          <div class="fade-up mb-12">
            <h2 class="text-2xl md:text-3xl font-extrabold text-white mb-4">Understanding Credit Scores</h2>
            <div class="text-white/55 text-sm leading-relaxed space-y-4">
              <p>
                Your credit score is one of the most influential factors in the mortgage process. It affects whether you qualify, what interest rate you'll receive, and how much you'll pay over the life of the loan. Even a small difference in rate can mean tens of thousands of dollars in savings or extra cost.
              </p>
            </div>
            <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-6">
              <div class="glass rounded-2xl p-5 hover-card text-center">
                <div class="text-red-400 text-xl font-extrabold mb-1">300-579</div>
                <div class="text-white text-xs font-bold mb-1">Poor</div>
                <div class="text-white/35 text-xs">Limited loan options. FHA may be possible with 10% down.</div>
              </div>
              <div class="glass rounded-2xl p-5 hover-card text-center">
                <div class="text-amber-400 text-xl font-extrabold mb-1">580-669</div>
                <div class="text-white text-xs font-bold mb-1">Fair</div>
                <div class="text-white/35 text-xs">FHA eligible with 3.5% down. Higher rates on conventional.</div>
              </div>
              <div class="glass rounded-2xl p-5 hover-card text-center">
                <div class="text-cyan-400 text-xl font-extrabold mb-1">670-739</div>
                <div class="text-white text-xs font-bold mb-1">Good</div>
                <div class="text-white/35 text-xs">Most loan types available. Competitive interest rates.</div>
              </div>
              <div class="glass rounded-2xl p-5 hover-card text-center">
                <div class="text-green-400 text-xl font-extrabold mb-1">740+</div>
                <div class="text-white text-xs font-bold mb-1">Excellent</div>
                <div class="text-white/35 text-xs">Best rates and terms. Maximum buying power.</div>
              </div>
            </div>
            <div class="text-white/55 text-sm leading-relaxed space-y-4 mt-6">
              <p>
                <strong class="text-white/70">How to improve your score quickly:</strong> Pay all bills on time, reduce credit card balances below 30% of your limit, avoid opening new credit accounts, and dispute any errors on your credit report. Even a few months of focused effort can make a meaningful difference.
              </p>
            </div>
          </div>

          <!-- Editorial Image -->
          <div class="fade-up mb-12 rounded-2xl overflow-hidden">
            <img
              src="https://images.unsplash.com/photo-1582268611958-ebfd161ef9cf?w=900&h=400&fit=crop"
              alt="Suburban neighborhood with tree-lined streets"
              class="w-full h-64 md:h-80 object-cover"
              loading="lazy"
            />
          </div>

          <!-- Section: Saving for Down Payment -->
          <div class="fade-up mb-12">
            <h2 class="text-2xl md:text-3xl font-extrabold text-white mb-4">Saving for a Down Payment</h2>
            <div class="text-white/55 text-sm leading-relaxed space-y-4">
              <p>
                The down payment is often the biggest hurdle for first-time buyers. The good news is that you may not need as much as you think. Several loan programs are designed specifically to make homeownership accessible with smaller down payments.
              </p>
            </div>
            <div class="glass rounded-2xl p-6 mt-6">
              <h3 class="text-white font-bold text-base mb-4">Down Payment by Loan Type</h3>
              <div class="space-y-3">
                <div class="flex justify-between items-center py-3 border-b border-white/6">
                  <div>
                    <span class="text-white text-sm font-bold">Conventional</span>
                    <span class="text-white/30 text-xs ml-2">Strong credit required</span>
                  </div>
                  <span class="text-cyan-500 font-bold text-sm">3% minimum</span>
                </div>
                <div class="flex justify-between items-center py-3 border-b border-white/6">
                  <div>
                    <span class="text-white text-sm font-bold">FHA</span>
                    <span class="text-white/30 text-xs ml-2">Flexible credit</span>
                  </div>
                  <span class="text-cyan-500 font-bold text-sm">3.5% minimum</span>
                </div>
                <div class="flex justify-between items-center py-3 border-b border-white/6">
                  <div>
                    <span class="text-white text-sm font-bold">VA</span>
                    <span class="text-white/30 text-xs ml-2">Veterans & military</span>
                  </div>
                  <span class="text-cyan-500 font-bold text-sm">0% down</span>
                </div>
                <div class="flex justify-between items-center py-3">
                  <div>
                    <span class="text-white text-sm font-bold">USDA</span>
                    <span class="text-white/30 text-xs ml-2">Rural & suburban areas</span>
                  </div>
                  <span class="text-cyan-500 font-bold text-sm">0% down</span>
                </div>
              </div>
            </div>
            <div class="text-white/55 text-sm leading-relaxed space-y-4 mt-6">
              <p>
                <strong class="text-white/70">Down payment assistance programs</strong> are available in most states and can provide grants or low-interest loans to help cover your down payment and closing costs. Many are specifically designed for first-time buyers. Ask your loan officer about programs available in your area.
              </p>
              <p>
                <strong class="text-white/70">Saving strategies:</strong> Set up automatic transfers to a dedicated savings account, reduce discretionary spending, consider a side income, and look into gift funds from family members (most loan programs allow this with proper documentation).
              </p>
            </div>
          </div>

          <!-- Section: Choosing the Right Loan -->
          <div class="fade-up mb-12">
            <h2 class="text-2xl md:text-3xl font-extrabold text-white mb-4">Choosing the Right Loan</h2>
            <div class="text-white/55 text-sm leading-relaxed space-y-4">
              <p>
                Not all mortgages are created equal. The right loan for you depends on your credit score, down payment, income, military status, and where you're buying. Here's a quick breakdown of the most common options for first-time buyers.
              </p>
            </div>
            <div class="grid sm:grid-cols-2 gap-4 mt-6">
              <div class="glass rounded-2xl p-6 hover-card">
                <div class="text-cyan-500 text-xs font-semibold uppercase tracking-wider mb-2">Most Popular</div>
                <h3 class="text-white text-base font-bold mb-2">Conventional Loan</h3>
                <p class="text-white/45 text-xs leading-relaxed">Best for buyers with good credit (620+) and at least 3% down. Offers competitive rates and the ability to drop PMI once you reach 20% equity. Available in both fixed and adjustable rate options.</p>
              </div>
              <div class="glass rounded-2xl p-6 hover-card">
                <div class="text-cyan-500 text-xs font-semibold uppercase tracking-wider mb-2">Flexible Credit</div>
                <h3 class="text-white text-base font-bold mb-2">FHA Loan</h3>
                <p class="text-white/45 text-xs leading-relaxed">Government-backed loan ideal for buyers with lower credit scores (580+). Requires just 3.5% down. Mortgage insurance is required, but qualification requirements are more lenient than conventional.</p>
              </div>
              <div class="glass rounded-2xl p-6 hover-card">
                <div class="text-cyan-500 text-xs font-semibold uppercase tracking-wider mb-2">Military Benefits</div>
                <h3 class="text-white text-base font-bold mb-2">VA Loan</h3>
                <p class="text-white/45 text-xs leading-relaxed">Exclusive to veterans, active military, and eligible spouses. No down payment required, no PMI, and often the lowest interest rates available. One of the best mortgage programs in existence.</p>
              </div>
              <div class="glass rounded-2xl p-6 hover-card">
                <div class="text-cyan-500 text-xs font-semibold uppercase tracking-wider mb-2">Rural Areas</div>
                <h3 class="text-white text-base font-bold mb-2">USDA Loan</h3>
                <p class="text-white/45 text-xs leading-relaxed">Zero down payment program for homes in eligible rural and suburban areas. Income limits apply. A great option for buyers who don't live in major metro areas.</p>
              </div>
            </div>
          </div>

          <!-- Editorial Image -->
          <div class="fade-up mb-12 rounded-2xl overflow-hidden">
            <img
              src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=900&h=400&fit=crop"
              alt="Beautiful home exterior with landscaping"
              class="w-full h-64 md:h-80 object-cover"
              loading="lazy"
            />
          </div>

          <!-- Section: Timeline -->
          <div class="fade-up mb-12">
            <h2 class="text-2xl md:text-3xl font-extrabold text-white mb-4">The Home Buying Process Timeline</h2>
            <div class="text-white/55 text-sm leading-relaxed space-y-4 mb-8">
              <p>
                From the moment you decide to buy to the day you get the keys, the typical home buying journey takes 3 to 6 months. Here's a realistic timeline broken into phases so you know what to expect.
              </p>
            </div>
            <div class="space-y-6">
              {timeline.map((phase) => (
                <div class="glass rounded-2xl p-6 hover-card">
                  <div class="flex items-start gap-4">
                    <div class="shrink-0 bg-cyan-500/10 border border-cyan-500/20 rounded-xl px-3 py-2">
                      <div class="text-cyan-500 text-xs font-bold whitespace-nowrap">{phase.phase}</div>
                    </div>
                    <div>
                      <h3 class="text-white text-base font-bold mb-3">{phase.title}</h3>
                      <ul class="space-y-2">
                        {phase.items.map((item) => (
                          <li class="flex items-start gap-2">
                            <svg class="w-4 h-4 text-cyan-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                            <span class="text-white/50 text-sm">{item}</span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- FAQ Section -->
          <div class="fade-up mb-12">
            <h2 class="text-2xl md:text-3xl font-extrabold text-white mb-6">Frequently Asked Questions</h2>
            <div class="space-y-4">
              <div class="glass rounded-2xl p-6">
                <h3 class="text-white font-bold text-sm mb-2">What credit score do I need to buy a house?</h3>
                <p class="text-white/50 text-sm leading-relaxed">The minimum depends on the loan type. Conventional loans typically require 620+, FHA loans require 580+ (or 500 with 10% down), and VA loans have no official minimum but most lenders prefer 620+. A score of 740+ qualifies you for the best rates.</p>
              </div>
              <div class="glass rounded-2xl p-6">
                <h3 class="text-white font-bold text-sm mb-2">What is the difference between pre-qualification and pre-approval?</h3>
                <p class="text-white/50 text-sm leading-relaxed">Pre-qualification is a quick estimate based on self-reported info. Pre-approval is a thorough process where a lender verifies your income, assets, and credit to issue a conditional commitment for a specific loan amount. Pre-approval carries much more weight with sellers.</p>
              </div>
              <div class="glass rounded-2xl p-6">
                <h3 class="text-white font-bold text-sm mb-2">How long does it take to buy a house from start to finish?</h3>
                <p class="text-white/50 text-sm leading-relaxed">The typical timeline is 3 to 6 months. This includes 1-2 months of preparation, 1-3 months of house hunting, and 30-45 days from accepted offer to closing.</p>
              </div>
              <div class="glass rounded-2xl p-6">
                <h3 class="text-white font-bold text-sm mb-2">What are closing costs and how much should I expect?</h3>
                <p class="text-white/50 text-sm leading-relaxed">Closing costs are fees paid at the time of purchase, typically 2-5% of the loan amount. They include appraisal fees, title insurance, attorney fees, origination charges, and prepaid items like property taxes and insurance.</p>
              </div>
              <div class="glass rounded-2xl p-6">
                <h3 class="text-white font-bold text-sm mb-2">Should I use a real estate agent as a first-time buyer?</h3>
                <p class="text-white/50 text-sm leading-relaxed">Yes. A buyer's agent provides expert guidance, helps you find homes, negotiates on your behalf, and coordinates with your lender and title company. In most cases, the seller pays the commission, so the service costs you nothing.</p>
              </div>
              <div class="glass rounded-2xl p-6">
                <h3 class="text-white font-bold text-sm mb-2">How much do I need for a down payment on my first home?</h3>
                <p class="text-white/50 text-sm leading-relaxed">First-time buyers have several low down payment options. Conventional loans allow as little as 3% down, FHA loans require 3.5%, and VA and USDA loans offer 0% down. Many state and local programs also provide down payment assistance.</p>
              </div>
            </div>
          </div>

        </article>

        <!-- Sidebar -->
        <aside class="fade-up">
          <div class="lg:sticky lg:top-28 space-y-6">
            <div class="glass rounded-2xl p-6">
              <h3 class="text-white text-sm font-bold mb-4">In This Guide</h3>
              <div class="space-y-1">
                <a href="#" class="block px-3 py-2 rounded-lg text-xs text-white/50 hover:text-white hover:bg-white/5 transition-all">Getting Started</a>
                <a href="#" class="block px-3 py-2 rounded-lg text-xs text-white/50 hover:text-white hover:bg-white/5 transition-all">Understanding Credit Scores</a>
                <a href="#" class="block px-3 py-2 rounded-lg text-xs text-white/50 hover:text-white hover:bg-white/5 transition-all">Saving for a Down Payment</a>
                <a href="#" class="block px-3 py-2 rounded-lg text-xs text-white/50 hover:text-white hover:bg-white/5 transition-all">Choosing the Right Loan</a>
                <a href="#" class="block px-3 py-2 rounded-lg text-xs text-white/50 hover:text-white hover:bg-white/5 transition-all">Buying Process Timeline</a>
                <a href="#" class="block px-3 py-2 rounded-lg text-xs text-white/50 hover:text-white hover:bg-white/5 transition-all">FAQ</a>
              </div>
            </div>

            <div class="glass rounded-2xl p-6">
              <h3 class="text-white text-sm font-bold mb-3">Related Articles</h3>
              <div class="space-y-2">
                <a href={url("/resources/how-much-house-can-you-afford")} class="block px-3 py-2.5 rounded-lg text-sm text-white/50 hover:text-white hover:bg-white/5 transition-all">
                  How Much House Can You Afford?
                </a>
                <a href={url("/resources/mortgage-rate-forecast")} class="block px-3 py-2.5 rounded-lg text-sm text-white/50 hover:text-white hover:bg-white/5 transition-all">
                  Mortgage Rate Forecast
                </a>
              </div>
            </div>

            <div class="glass rounded-2xl p-6">
              <h3 class="text-white text-sm font-bold mb-3">Free Tools</h3>
              <div class="space-y-2">
                <a href={url("/tools/mortgage-calculator")} class="block px-3 py-2.5 rounded-lg text-sm text-white/50 hover:text-white hover:bg-white/5 transition-all">
                  Mortgage Calculator
                </a>
                <a href={url("/tools/affordability-calculator")} class="block px-3 py-2.5 rounded-lg text-sm text-white/50 hover:text-white hover:bg-white/5 transition-all">
                  Affordability Calculator
                </a>
                <a href={url("/tools/refinance-calculator")} class="block px-3 py-2.5 rounded-lg text-sm text-white/50 hover:text-white hover:bg-white/5 transition-all">
                  Refinance Calculator
                </a>
              </div>
            </div>

            <div class="bg-gradient-to-br from-cyan-500/15 to-cyan-600/10 rounded-2xl p-6 border border-cyan-500/20">
              <h3 class="text-white text-sm font-bold mb-2">Ready to Take the First Step?</h3>
              <p class="text-white/50 text-xs leading-relaxed mb-4">
                Get pre-approved in minutes and find out exactly what you qualify for. No commitment required.
              </p>
              <a href={url("/apply")} class="block bg-cyan-500 hover:bg-cyan-400 text-white text-center py-3 rounded-xl font-bold text-sm transition-colors">
                Get Pre-Approved &rarr;
              </a>
            </div>
          </div>
        </aside>

      </div>
    </div>
  </section>

  <!-- ==================== CTA ==================== -->
  <section class="relative overflow-hidden">
    <img
      src="https://images.unsplash.com/photo-1600585154526-990dced4db0d?w=1600&h=500&fit=crop"
      alt="Warm and inviting modern home"
      class="absolute inset-0 w-full h-full object-cover"
      loading="lazy"
    />
