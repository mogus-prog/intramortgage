---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loanPrograms } from '../../data/loanPrograms';
import { url } from '../../utils/links';

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Mortgage Loan Programs",
  "description": "Explore all mortgage loan programs available at Intra Mortgage",
  "itemListElement": loanPrograms.map((loan, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": loan.title,
    "url": `https://intramortgage.com/loans/${loan.slug}`
  }))
};
---

<BaseLayout
  title="Mortgage Loan Programs | Intra Mortgage"
  description="Explore our full range of mortgage loan programs — Conventional, FHA, VA, USDA, Jumbo, Refinance, and First-Time Buyer programs. Find the right loan for your situation."
  schema={schema}
>
  <!-- Hero -->
  <section class="relative overflow-hidden -mt-18">
    <img
      src="https://images.unsplash.com/photo-1582268611958-ebfd161ef9cf?w=1600&h=600&fit=crop"
      alt="Beautiful home"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-navy-950/95 via-navy-950/85 to-navy-950/50"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-36 pb-16">
      <p class="text-cyan-500 text-xs font-semibold tracking-[3px] uppercase mb-3">Loan Programs</p>
      <h1 class="text-4xl md:text-5xl font-extrabold text-white leading-tight mb-4">A Loan for Every Story</h1>
      <p class="text-white/60 text-lg max-w-2xl">Every homeowner's journey is unique. Whether you're buying, refinancing, or exploring your options, we have the right program for you.</p>
    </div>
  </section>

  <!-- Loan Grid -->
  <section class="section-padding bg-navy-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {loanPrograms.map((loan) => (
          <a href={url(`/loans/${loan.slug}`)} class="group block rounded-2xl overflow-hidden border border-white/8 hover-card bg-white/[0.02]">
            <div class="overflow-hidden">
              <img src={loan.heroImg} alt={loan.title} class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <div class="p-6">
              <h2 class="text-white text-xl font-bold mb-2">{loan.title}</h2>
              <p class="text-white/50 text-sm leading-relaxed mb-4">{loan.tagline}</p>
              <div class="grid grid-cols-3 gap-3 mb-4">
                <div>
                  <div class="text-cyan-500 text-lg font-bold">{loan.minDownPayment}</div>
                  <div class="text-white/30 text-[10px] uppercase tracking-wider">Min. Down</div>
                </div>
                <div>
                  <div class="text-cyan-500 text-lg font-bold">{loan.minCreditScore}</div>
                  <div class="text-white/30 text-[10px] uppercase tracking-wider">Min. Score</div>
                </div>
                <div class="col-span-1">
                  <div class="text-cyan-500 text-sm font-semibold group-hover:translate-x-1 transition-transform mt-1">Learn More →</div>
                </div>
              </div>
              <p class="text-white/35 text-xs"><span class="text-white/50 font-medium">Best for:</span> {loan.bestFor}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-navy-900 border-t border-white/5">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
      <h2 class="text-2xl md:text-3xl font-extrabold text-white mb-4">Not Sure Which Loan Is Right for You?</h2>
      <p class="text-white/50 text-sm mb-8">Our mortgage experts will help you find the perfect program for your situation. Get a free, no-obligation consultation.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={url("/apply")} class="bg-cyan-500 hover:bg-cyan-400 text-white font-bold px-8 py-4 rounded-xl transition-colors">Get Pre-Approved →</a>
        <a href={url("/company/contact")} class="bg-white/5 hover:bg-white/10 text-white font-semibold px-8 py-4 rounded-xl border border-white/10 transition-colors">Talk to an Expert</a>
      </div>
    </div>
  </section>
</BaseLayout>
