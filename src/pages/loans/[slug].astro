---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ChatInput from '../../components/ChatInput.tsx';
import { loanPrograms } from '../../data/loanPrograms';
import type { LoanProgram } from '../../data/loanPrograms';
import { url } from '../../utils/links';

export function getStaticPaths() {
  return loanPrograms.map((loan) => ({
    params: { slug: loan.slug },
    props: { loan },
  }));
}

interface Props {
  loan: LoanProgram;
}

const { loan } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "FinancialProduct",
  "name": loan.title,
  "description": loan.description,
  "provider": {
    "@type": "MortgageBroker",
    "name": "Intra Mortgage",
    "url": "https://intramortgage.com"
  },
  "url": `https://intramortgage.com/loans/${loan.slug}`
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": loan.faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

<BaseLayout
  title={`${loan.title} | Intra Mortgage`}
  description={loan.description}
  schema={schema}
>
  <!-- Hero -->
  <section class="relative overflow-hidden -mt-18">
    <img
      src={loan.heroImg}
      alt={loan.title}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-navy-950/95 via-navy-950/85 to-navy-950/40"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-36 pb-16">
      <a href={url("/loans")} class="text-cyan-500 text-xs font-semibold hover:text-cyan-400 transition-colors mb-4 inline-block">← All Loan Programs</a>
      <h1 class="text-4xl md:text-5xl font-extrabold text-white leading-tight mb-3">{loan.title}</h1>
      <p class="text-white/60 text-lg max-w-2xl mb-6">{loan.tagline}</p>
      <div class="flex flex-wrap gap-6">
        <div class="glass rounded-xl px-5 py-3">
          <div class="text-cyan-500 text-2xl font-extrabold">{loan.minDownPayment}</div>
          <div class="text-white/40 text-xs">Min. Down Payment</div>
        </div>
        <div class="glass rounded-xl px-5 py-3">
          <div class="text-cyan-500 text-2xl font-extrabold">{loan.minCreditScore}</div>
          <div class="text-white/40 text-xs">Min. Credit Score</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="section-padding bg-navy-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-12">
        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-12">
          <!-- Description -->
          <div class="fade-up">
            <h2 class="text-2xl font-extrabold text-white mb-4">Overview</h2>
            <p class="text-white/60 text-base leading-relaxed">{loan.description}</p>
            <p class="text-white/45 text-sm mt-3"><strong class="text-white/60">Best for:</strong> {loan.bestFor}</p>
          </div>

          <!-- Features -->
          <div class="fade-up">
            <h2 class="text-2xl font-extrabold text-white mb-6">Key Features</h2>
            <div class="grid sm:grid-cols-2 gap-3">
              {loan.features.map((feature) => (
                <div class="glass rounded-xl p-4 flex items-start gap-3">
                  <div class="w-6 h-6 bg-cyan-500/15 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                    <svg class="w-3.5 h-3.5 text-cyan-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                    </svg>
                  </div>
                  <span class="text-white/70 text-sm">{feature}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Requirements -->
          <div class="fade-up">
            <h2 class="text-2xl font-extrabold text-white mb-6">Requirements</h2>
            <div class="space-y-3">
              {loan.requirements.map((req) => (
                <div class="flex items-start gap-3">
                  <div class="w-2 h-2 bg-cyan-500 rounded-full mt-2 flex-shrink-0"></div>
                  <span class="text-white/60 text-sm">{req}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- FAQs -->
          <div class="fade-up">
            <h2 class="text-2xl font-extrabold text-white mb-6">Frequently Asked Questions</h2>
            <div class="space-y-4">
              {loan.faqs.map((faq) => (
                <details class="glass rounded-xl group">
                  <summary class="p-5 cursor-pointer text-white font-semibold text-sm flex justify-between items-center list-none">
                    {faq.question}
                    <svg class="w-5 h-5 text-white/30 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </summary>
                  <div class="px-5 pb-5 text-white/55 text-sm leading-relaxed border-t border-white/5 pt-4">
                    {faq.answer}
                  </div>
                </details>
              ))}
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <!-- CTA Card -->
          <div class="glass rounded-2xl p-6 sticky top-24">
            <h3 class="text-white font-bold text-lg mb-2">Ready to Get Started?</h3>
            <p class="text-white/45 text-sm mb-6">Get a personalized rate quote for your {loan.shortTitle} loan in minutes.</p>
            <a href={url("/apply")} class="block bg-cyan-500 hover:bg-cyan-400 text-white text-center py-3.5 rounded-xl font-bold text-sm transition-colors mb-3">
              Get Pre-Approved →
            </a>
            <a href={url("/company/contact")} class="block bg-white/5 hover:bg-white/10 text-white text-center py-3.5 rounded-xl font-semibold text-sm border border-white/10 transition-colors mb-6">
              Talk to an Expert
            </a>

            <div class="border-t border-white/8 pt-5">
              <p class="text-white/50 text-xs mb-3 font-medium">Have a question?</p>
              <ChatInput client:visible variant="hero" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</BaseLayout>
