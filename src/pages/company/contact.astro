---
import BaseLayout from '../../layouts/BaseLayout.astro';

const contactInfo = [
  {
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>`,
    label: "Phone",
    value: "(800) 555-0199",
    href: "tel:+18005550199",
    detail: "Mon–Fri 8am–8pm, Sat 9am–5pm ET",
  },
  {
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`,
    label: "Email",
    value: "hello@intramortgage.com",
    href: "mailto:hello@intramortgage.com",
    detail: "We respond within 2 business hours",
  },
  {
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
    label: "Office",
    value: "123 Financial District Blvd, Suite 400",
    href: "#",
    detail: "New York, NY 10004",
  },
];

const hours = [
  { day: "Monday – Friday", time: "8:00 AM – 8:00 PM ET" },
  { day: "Saturday", time: "9:00 AM – 5:00 PM ET" },
  { day: "Sunday", time: "Closed" },
];

const loanTypes = [
  "Select a loan type",
  "Home Purchase",
  "Refinance",
  "Cash-Out Refinance",
  "FHA Loan",
  "VA Loan",
  "Jumbo Loan",
  "Other / Not Sure",
];
---

<BaseLayout
  title="Contact Us — Get in Touch | Intra Mortgage"
  description="Reach out to Intra Mortgage for personalized mortgage guidance. Call, email, or fill out our contact form. Our expert team is ready to help you find the right loan."
  canonicalUrl="/company/contact"
>

  <!-- ==================== HERO ==================== -->
  <section class="relative overflow-hidden -mt-18">
    <img
      src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=1600&h=600&fit=crop&crop=center"
      alt="Professional mortgage consultation"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-navy-950/95 via-navy-950/85 to-navy-950/50"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-36 pb-20 md:pt-44 md:pb-24">
      <div class="max-w-2xl">
        <p class="text-cyan-500 text-xs font-semibold tracking-[3px] uppercase mb-4">
          Get in Touch
        </p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-[1.08] mb-6">
          We're Here<br />to <span class="text-gradient">Help</span>
        </h1>
        <p class="text-white/65 text-base md:text-lg leading-relaxed max-w-xl">
          Have a question about rates, loan programs, or the homebuying process? Our team is ready to provide personalized guidance — no pressure, no obligations.
        </p>
      </div>
    </div>
  </section>

  <!-- ==================== BREADCRUMB ==================== -->
  <div class="bg-navy-900 border-b border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <nav class="flex items-center gap-2 text-xs text-white/40" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/company/about" class="hover:text-white transition-colors">Company</a>
        <span>/</span>
        <span class="text-white/70">Contact</span>
      </nav>
    </div>
  </div>

  <!-- ==================== CONTACT SPLIT LAYOUT ==================== -->
  <section class="section-padding bg-navy-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-[1fr_1.2fr] gap-10">

        <!-- LEFT: Contact Info -->
        <div class="fade-up">
          <div class="glass rounded-2xl p-7 md:p-8">
            <h2 class="text-white text-xl font-bold mb-6">Contact Information</h2>

            <div class="space-y-6">
              {contactInfo.map((item) => (
                <a href={item.href} class="flex gap-4 group">
                  <div class="w-11 h-11 bg-cyan-500/10 border border-cyan-500/20 rounded-xl flex items-center justify-center text-cyan-500 flex-shrink-0 group-hover:bg-cyan-500/20 transition-colors">
                    <Fragment set:html={item.icon} />
                  </div>
                  <div>
                    <p class="text-white/40 text-xs uppercase tracking-wider mb-0.5">{item.label}</p>
                    <p class="text-white text-sm font-semibold group-hover:text-cyan-400 transition-colors">{item.value}</p>
                    <p class="text-white/30 text-xs mt-0.5">{item.detail}</p>
                  </div>
                </a>
              ))}
            </div>

            <!-- Business Hours -->
            <div class="mt-8 pt-6 border-t border-white/8">
              <h3 class="text-white text-sm font-bold mb-4">Business Hours</h3>
              <div class="space-y-3">
                {hours.map((h) => (
                  <div class="flex justify-between items-center">
                    <span class="text-white/50 text-sm">{h.day}</span>
                    <span class="text-white text-sm font-medium">{h.time}</span>
                  </div>
                ))}
              </div>
            </div>

            <!-- Quick Links -->
            <div class="mt-8 pt-6 border-t border-white/8">
              <h3 class="text-white text-sm font-bold mb-4">Quick Actions</h3>
              <div class="space-y-2">
                <a href="/apply" class="flex items-center gap-2 text-cyan-500 text-sm font-semibold hover:text-cyan-400 transition-colors">
                  <span>&rarr;</span> Start Your Application
                </a>
                <a href="/tools/mortgage-calculator" class="flex items-center gap-2 text-cyan-500 text-sm font-semibold hover:text-cyan-400 transition-colors">
                  <span>&rarr;</span> Use Our Calculator
                </a>
                <a href="/resources" class="flex items-center gap-2 text-cyan-500 text-sm font-semibold hover:text-cyan-400 transition-colors">
                  <span>&rarr;</span> Browse Learning Center
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- RIGHT: Contact Form -->
        <div class="fade-up">
          <div class="glass rounded-2xl p-7 md:p-8">
            <h2 class="text-white text-xl font-bold mb-2">Send Us a Message</h2>
            <p class="text-white/40 text-sm mb-8">
              Fill out the form below and a mortgage expert will get back to you within 2 hours during business hours.
            </p>

            <form class="space-y-5" id="contact-form">
              <!-- Name Row -->
              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label for="first-name" class="block text-white/60 text-xs font-medium mb-2">First Name *</label>
                  <input
                    type="text"
                    id="first-name"
                    name="first-name"
                    required
                    class="w-full bg-white/[0.06] border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder:text-white/25 focus:outline-none focus:border-cyan-500/50 focus:bg-white/[0.08] transition-all"
                    placeholder="John"
                  />
                </div>
                <div>
                  <label for="last-name" class="block text-white/60 text-xs font-medium mb-2">Last Name *</label>
                  <input
                    type="text"
                    id="last-name"
                    name="last-name"
                    required
                    class="w-full bg-white/[0.06] border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder:text-white/25 focus:outline-none focus:border-cyan-500/50 focus:bg-white/[0.08] transition-all"
                    placeholder="Doe"
                  />
                </div>
              </div>

              <!-- Email -->
              <div>
                <label for="email" class="block text-white/60 text-xs font-medium mb-2">Email Address *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full bg-white/[0.06] border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder:text-white/25 focus:outline-none focus:border-cyan-500/50 focus:bg-white/[0.08] transition-all"
                  placeholder="john@example.com"
                />
              </div>

              <!-- Phone -->
              <div>
                <label for="phone" class="block text-white/60 text-xs font-medium mb-2">Phone Number</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class="w-full bg-white/[0.06] border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder:text-white/25 focus:outline-none focus:border-cyan-500/50 focus:bg-white/[0.08] transition-all"
                  placeholder="(555) 123-4567"
                />
              </div>

              <!-- Loan Type -->
              <div>
                <label for="loan-type" class="block text-white/60 text-xs font-medium mb-2">Loan Type</label>
                <select
                  id="loan-type"
                  name="loan-type"
                  class="w-full bg-white/[0.06] border border-white/10 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-cyan-500/50 focus:bg-white/[0.08] transition-all appearance-none"
                  style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 fill=%22none%22 viewBox=%220 0 24 24%22 stroke=%22rgba(255,255,255,0.4)%22><path stroke-linecap=%22round%22 stroke-linejoin=%22round%22 stroke-width=%222%22 d=%22M19 9l-7 7-7-7%22/></svg>'); background-repeat: no-repeat; background-position: right 12px center; background-size: 16px;"
                >
                  {loanTypes.map((type, i) => (
                    <option value={i === 0 ? "" : type} disabled={i === 0} selected={i === 0} class="bg-navy-900">
                      {type}
                    </option>
                  ))}
                </select>
              </div>

              <!-- Message -->
              <div>
                <label for="message" class="block text-white/60 text-xs font-medium mb-2">Your Message *</label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="5"
                  class="w-full bg-white/[0.06] border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder:text-white/25 focus:outline-none focus:border-cyan-500/50 focus:bg-white/[0.08] transition-all resize-none"
                  placeholder="Tell us about your situation, questions, or how we can help..."
                ></textarea>
              </div>

              <!-- Submit -->
              <button
                type="submit"
                class="w-full bg-cyan-500 hover:bg-cyan-400 text-white text-sm font-bold py-4 rounded-xl transition-colors"
              >
                Send Message &rarr;
              </button>

              <p class="text-white/25 text-xs text-center">
                By submitting this form, you agree to our privacy policy. We'll never share your information with third parties.
              </p>
            </form>

            <!-- Success message (hidden by default) -->
            <div id="form-success" class="hidden text-center py-12">
              <div class="w-16 h-16 bg-cyan-500/15 border border-cyan-500/30 rounded-full flex items-center justify-center mx-auto mb-5">
                <svg class="w-8 h-8 text-cyan-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="text-white text-xl font-bold mb-2">Message Sent!</h3>
              <p class="text-white/50 text-sm">
                Thank you for reaching out. A mortgage expert will be in touch within 2 business hours.
              </p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ==================== MAP / ADDITIONAL CTA ==================== -->
  <section class="section-padding bg-gradient-to-b from-navy-950 to-navy-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="glass rounded-2xl p-8 md:p-12 text-center fade-up">
        <p class="text-cyan-500 text-xs font-semibold tracking-[3px] uppercase mb-3">Prefer to Talk?</p>
        <h2 class="text-2xl md:text-3xl font-extrabold text-white mb-3">
          Call Us — We Pick Up the Phone
        </h2>
        <p class="text-white/45 text-sm max-w-lg mx-auto mb-8">
          No phone trees, no runaround. You'll be connected with a real mortgage expert who can answer your questions right away.
        </p>
        <a
          href="tel:+18005550199"
          class="inline-flex items-center gap-2 bg-cyan-500 hover:bg-cyan-400 text-white text-sm font-bold px-10 py-4 rounded-xl transition-colors"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          (800) 555-0199
        </a>
        <p class="text-white/30 text-xs mt-4">Mon–Fri 8am–8pm, Sat 9am–5pm ET</p>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  // Simple form submission handler
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    // In production, this would send to an API
    form.style.display = 'none';
    if (success) success.classList.remove('hidden');
  });
</script>
