---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { states } from '../../data/states';
import { loanPrograms } from '../../data/loanPrograms';
import { url } from '../../utils/links';

const sortedStates = [...states].sort((a, b) => a.name.localeCompare(b.name));

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Mortgage Loans by State — Intra Mortgage",
  "description": "Explore mortgage loan options available in all 50 states. Intra Mortgage is licensed nationwide with local expertise in every market.",
  "itemListElement": sortedStates.map((state, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": `Mortgage Loans in ${state.name}`,
    "url": `https://intramortgage.com/states/${state.slug}`
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://intramortgage.com" },
    { "@type": "ListItem", "position": 2, "name": "States", "item": "https://intramortgage.com/states" }
  ]
};

const totalCities = states.reduce((sum, s) => sum + s.cities.length, 0);
---

<BaseLayout
  title="Mortgage Loans by State | We Lend Nationwide | Intra Mortgage"
  description="Explore mortgage loan options in every state. Intra Mortgage is licensed nationwide — find local rates, loan programs, and expert guidance in your state."
  schema={schema}
>

  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Hero -->
  <section class="relative overflow-hidden -mt-18">
    <img
      src="https://images.unsplash.com/photo-1501594907352-04cda38ebc29?w=1600&h=600&fit=crop"
      alt="Aerial view of American neighborhoods"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-navy-950/95 via-navy-950/85 to-navy-950/50"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-36 pb-16">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-xs text-white/40 mb-6">
        <a href={url("/")} class="hover:text-cyan-500 transition-colors">Home</a>
        <span>/</span>
        <span class="text-white/60">States</span>
      </nav>

      <p class="text-cyan-500 text-xs font-semibold tracking-[3px] uppercase mb-3">Licensed in All 50 States</p>
      <h1 class="text-4xl md:text-5xl font-extrabold text-white leading-tight mb-4">We Lend Nationwide</h1>
      <p class="text-white/60 text-lg max-w-2xl">
        No matter where you're buying, Intra Mortgage has you covered. Find local rates, loan programs, and expert guidance tailored to your state's housing market.
      </p>
    </div>
  </section>

  <!-- Trust Bar -->
  <section class="bg-navy-900 border-y border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-0">
        <div class="text-center md:border-r md:border-white/8">
          <div class="text-cyan-500 text-2xl md:text-3xl font-extrabold">50 States</div>
          <div class="text-white/45 text-xs mt-1">Licensed Nationwide</div>
        </div>
        <div class="text-center md:border-r md:border-white/8">
          <div class="text-cyan-500 text-2xl md:text-3xl font-extrabold">{loanPrograms.length}+</div>
          <div class="text-white/45 text-xs mt-1">Loan Programs</div>
        </div>
        <div class="text-center md:border-r md:border-white/8">
          <div class="text-cyan-500 text-2xl md:text-3xl font-extrabold">{totalCities}+</div>
          <div class="text-white/45 text-xs mt-1">Major Markets Served</div>
        </div>
        <div class="text-center">
          <div class="text-cyan-500 text-2xl md:text-3xl font-extrabold">21 Days</div>
          <div class="text-white/45 text-xs mt-1">Average Close Time</div>
        </div>
      </div>
    </div>
  </section>

  <!-- US Map Placeholder -->
  <section class="section-padding bg-navy-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10 fade-up">
        <p class="text-cyan-500 text-xs font-semibold tracking-[3px] uppercase mb-3">Find Your State</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-white">Select Your State to Get Started</h2>
        <p class="text-white/45 text-sm mt-3">Click on your state below for local rates, programs, and market insights</p>
      </div>

      <!-- Map Placeholder -->
      <div class="glass rounded-2xl p-8 md:p-12 text-center mb-16 fade-up">
        <div class="max-w-lg mx-auto">
          <svg class="w-16 h-16 mx-auto text-cyan-500/50 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <p class="text-white/40 text-sm">Interactive US map coming soon</p>
          <p class="text-white/25 text-xs mt-1">Browse states in the grid below</p>
        </div>
      </div>

      <!-- State Grid -->
      <div class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
        {sortedStates.map((state) => (
          <a
            href={url(`/states/${state.slug}`)}
            class="group block glass rounded-xl p-5 hover-card"
          >
            <div class="flex items-center justify-between mb-3">
              <span class="text-cyan-500 text-xs font-bold bg-cyan-500/10 px-2.5 py-1 rounded-lg">{state.abbreviation}</span>
              <svg class="w-4 h-4 text-white/20 group-hover:text-cyan-500 group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
            <h3 class="text-white font-bold text-sm mb-1">{state.name}</h3>
            <p class="text-white/30 text-xs">{state.cities.length} major cities</p>
            <p class="text-white/25 text-[10px] mt-2">Loan limit: {state.conformingLoanLimit}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Loan Programs Overview -->
  <section class="section-padding bg-gradient-to-b from-navy-950 to-navy-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 fade-up">
        <p class="text-cyan-500 text-xs font-semibold tracking-[3px] uppercase mb-3">Available Everywhere</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-white">Loan Programs Available Nationwide</h2>
        <p class="text-white/45 text-sm mt-3">Every one of our loan programs is available in all 50 states</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {loanPrograms.slice(0, 4).map((loan) => (
          <a href={url(`/loans/${loan.slug}`)} class="group block glass rounded-xl p-5 hover-card">
            <h3 class="text-white font-bold text-sm mb-1">{loan.title}</h3>
            <p class="text-white/40 text-xs leading-relaxed mb-3">{loan.tagline}</p>
            <div class="flex items-center gap-3 text-xs">
              <span class="text-cyan-500 font-semibold">{loan.minDownPayment} down</span>
              <span class="text-white/20">|</span>
              <span class="text-white/40">{loan.minCreditScore} min. score</span>
            </div>
            <p class="text-cyan-500 text-xs font-semibold mt-3 group-hover:translate-x-1 transition-transform">Learn More →</p>
          </a>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href={url("/loans")} class="text-cyan-500 text-sm font-semibold hover:text-cyan-400 transition-colors">View All Loan Programs →</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative overflow-hidden">
    <img
      src="https://images.unsplash.com/photo-1600585154526-990dced4db0d?w=1600&h=500&fit=crop"
      alt="Beautiful home"
      class="absolute inset-0 w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-cyan-500/92 to-cyan-600/88"></div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-3">Ready to Get Started?</h2>
      <p class="text-white/85 text-base mb-8">No matter where you're buying, our team is ready to help you find the best mortgage for your situation.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={url("/apply")} class="bg-white text-cyan-600 font-bold px-10 py-4 rounded-xl hover:bg-white/90 transition-colors">Get Pre-Approved →</a>
        <a href={url("/company/contact")} class="bg-white/15 text-white font-semibold px-10 py-4 rounded-xl border border-white/25 hover:bg-white/25 transition-colors">Talk to an Expert</a>
      </div>
      <p class="text-white/60 text-sm mt-6">
        Or call us directly: <a href="tel:+18005550199" class="text-white font-bold hover:underline">(800) 555-0199</a>
      </p>
    </div>
  </section>

</BaseLayout>
